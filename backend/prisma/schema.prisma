generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id       Int    @id @default(autoincrement())
  nome     String
  email    String @unique
  telefone String

  pedidos Pedido[]

  createdAt DateTime @default(now())
}

model Produto {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String?
  preco     Float
  imagem    String?
  estoque   Int      @default(0)
  createdAt DateTime @default(now())
}

model Pedido {
  id Int @id @default(autoincrement())

  usuarioId Int?

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  total  Float
  status String @default("pendente")

  cliente    String?
  email      String?
  telefone   String?
  endereco   String?
  observacao String?

  itens Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Visita {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
}
