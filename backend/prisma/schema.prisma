generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  createdAt DateTime @default(now())
}

model Produto {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String?
  preco     Float
  imagem    String?
  estoque   Int      @default(0)
  createdAt DateTime @default(now())
  }
  
 model Pedido {
  id         Int      @id @default(autoincrement())

  // itens do carrinho (produtos + foto do cliente)
  itens      Json

  // total da compra
  total      Float

  // status do pedido (produção)
  status     String   @default("pendente")

  // identificação do cliente (simples por enquanto)
  clienteId  String?  

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}