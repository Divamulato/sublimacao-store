generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  createdAt DateTime @default(now())
}

model Produto {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String?
  preco     Float
  imagem    String?
  estoque   Int      @default(0)
  createdAt DateTime @default(now())
  }
  
 model Pedido {
  id          Int      @id @default(autoincrement())

  total       Float
  status      String   @default("pendente")

  cliente     String?
  telefone    String?
  endereco    String?
  observacao  String?

  itens       Json

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Visita {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
}